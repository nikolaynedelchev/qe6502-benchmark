# Generate a C++ header of `#define ICON_MD_<NAME> "<UTF-8>"` from a
# Google Material Icons `.codepoints` file (lines of the form `name hex`).
#
# Usage:
#   cmake -DINPUT=<path-to-.codepoints>
#         -DOUTPUT=<path-to-generated-header>
#         -P gen_icon_codepoints.cmake
#
# Every entry's hex value is encoded as a 3-byte UTF-8 escape sequence
# (all Material Icons codepoints fall in U+E000..U+FFFF, which is the
# BMP range that always encodes to exactly three UTF-8 bytes), so the
# emitted macros can be concatenated with plain C string literals.

if(POLICY CMP0057)
    cmake_policy(SET CMP0057 NEW)
endif()

if(NOT DEFINED INPUT OR NOT DEFINED OUTPUT)
    message(FATAL_ERROR "gen_icon_codepoints.cmake: INPUT and OUTPUT required")
endif()
if(NOT EXISTS "${INPUT}")
    message(FATAL_ERROR "gen_icon_codepoints.cmake: input not found: ${INPUT}")
endif()

# Lowercase hex digit table for fast int -> 2-digit hex conversion below.
set(HEX_DIGITS "0123456789abcdef")

function(int_to_hex2 outvar val)
    math(EXPR hi "(${val} >> 4) & 0xF")
    math(EXPR lo "${val} & 0xF")
    string(SUBSTRING "${HEX_DIGITS}" ${hi} 1 hic)
    string(SUBSTRING "${HEX_DIGITS}" ${lo} 1 loc)
    set(${outvar} "${hic}${loc}" PARENT_SCOPE)
endfunction()

file(STRINGS "${INPUT}" lines)
list(LENGTH lines lineCount)

set(content "// Auto-generated by cmake/gen_icon_codepoints.cmake — do not edit.\n")
string(APPEND content "// Source: MaterialIcons-Regular.codepoints (${lineCount} icons)\n")
string(APPEND content "//\n")
string(APPEND content "// Each macro expands to the UTF-8 encoding of a Material Icons code\n")
string(APPEND content "// point, suitable for concatenation with a plain string literal, e.g.\n")
string(APPEND content "//   ATTouchButton(\"Resume\", size, style, ICON_MD_PLAY_ARROW);\n")
string(APPEND content "// Render it with the icon ImFont (ATUIGetFontIcon()).\n")
string(APPEND content "#pragma once\n\n")

set(seen_names "")
foreach(line IN LISTS lines)
    if(NOT line MATCHES "^([A-Za-z0-9_]+)[ \t]+([0-9A-Fa-f]+)$")
        continue()
    endif()
    set(name "${CMAKE_MATCH_1}")
    set(hex  "${CMAKE_MATCH_2}")

    # The upstream codepoints file occasionally lists the same name twice
    # (e.g. "flourescent" was assigned two glyphs over the years).  Skip
    # the second occurrence so the emitted header doesn't produce a
    # macro-redefinition warning on every TU that includes it.
    if(name IN_LIST seen_names)
        continue()
    endif()
    list(APPEND seen_names "${name}")

    # Codepoint as an integer.  All Material Icons live in U+E000..U+FFFF
    # which is 3-byte UTF-8 territory; refuse anything outside that range
    # rather than emit a malformed escape sequence.  CMake's `math()`
    # comparison operator only accepts a single expression, not chained
    # numeric literals, so normalise to a decimal value first via math.
    math(EXPR cp_dec "0x${hex}")
    if(cp_dec LESS 57344 OR cp_dec GREATER 65535) # 57344 = 0xE000, 65535 = 0xFFFF
        message(WARNING "gen_icon_codepoints.cmake: skipping out-of-range ${name} U+${hex}")
        continue()
    endif()
    set(cp "${cp_dec}")

    # UTF-8 encode the 16-bit codepoint into three bytes:
    #   1110xxxx 10xxxxxx 10xxxxxx
    math(EXPR b1 "0xE0 | ((${cp} >> 12) & 0x0F)")
    math(EXPR b2 "0x80 | ((${cp} >>  6) & 0x3F)")
    math(EXPR b3 "0x80 |  (${cp}        & 0x3F)")
    int_to_hex2(b1h ${b1})
    int_to_hex2(b2h ${b2})
    int_to_hex2(b3h ${b3})

    string(TOUPPER "${name}" UNAME)
    string(APPEND content "#define ICON_MD_${UNAME} \"\\x${b1h}\\x${b2h}\\x${b3h}\"\n")
endforeach()

# Atomic write so a partial file from an aborted build is never observed.
file(WRITE "${OUTPUT}.tmp" "${content}")
file(RENAME "${OUTPUT}.tmp" "${OUTPUT}")
