# Embed a binary file as a C++ source containing a `const unsigned char[]`.
#
# Usage:
#   cmake -DINPUT=<path-to-binary>
#         -DOUTPUT=<path-to-generated.cpp>
#         -DSYMBOL=<C identifier>
#         -P embed_font.cmake
#
# Produces a .cpp that defines:
#   extern const unsigned char  <SYMBOL>[];
#   extern const unsigned int   <SYMBOL>_size;
#
# Used to bake bundled TTF fonts into the AltirraSDL binary so the UI never
# has to depend on a runtime fonts/ directory existing — works on all
# platforms (desktop, Android assets, sandboxed installs) and avoids the
# need for a host build tool when cross-compiling.

if(NOT DEFINED INPUT OR NOT DEFINED OUTPUT OR NOT DEFINED SYMBOL)
    message(FATAL_ERROR "embed_font.cmake: INPUT, OUTPUT, SYMBOL all required")
endif()

if(NOT EXISTS "${INPUT}")
    message(FATAL_ERROR "embed_font.cmake: input file not found: ${INPUT}")
endif()

file(READ "${INPUT}" hex HEX)
string(LENGTH "${hex}" hex_len)
math(EXPR num_bytes "${hex_len} / 2")

# Insert "0x" prefix + comma after every two hex chars.
string(REGEX REPLACE "([0-9a-f][0-9a-f])" "0x\\1," hex "${hex}")

get_filename_component(input_name "${INPUT}" NAME)

set(content "// Auto-generated by cmake/embed_font.cmake — do not edit.\n")
set(content "${content}// Source: ${input_name}\n\n")
set(content "${content}extern \"C\" {\n")
# `extern` is REQUIRED here: in C++, namespace-scope `const` variables have
# internal linkage by default, and the `extern \"C\"` block only changes
# name mangling — not storage class.  Without `extern` the symbols would
# be invisible to the linker and references in ui_fonts.cpp would fail.
set(content "${content}extern const unsigned char ${SYMBOL}[] = {\n")
set(content "${content}${hex}\n")
set(content "${content}};\n")
set(content "${content}extern const unsigned int ${SYMBOL}_size = ${num_bytes}u;\n")
set(content "${content}}\n")

# Write atomically so a partial file from an aborted build never leaves
# the .cpp in a half-state that the next build picks up.
file(WRITE "${OUTPUT}.tmp" "${content}")
file(RENAME "${OUTPUT}.tmp" "${OUTPUT}")
