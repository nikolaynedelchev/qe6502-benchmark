# generate_buildinfo.cmake — Stamps build date/time, git commit, and platform
# into a C++ header.  Invoked at BUILD time (not configure time) so the
# timestamp reflects the actual build, not the last cmake configure.
#
# Expected variables (passed via -D on the command line):
#   OUTPUT_FILE  — absolute path to the generated header
#   SOURCE_DIR   — repo root (for git)
#   PROJECT_VER  — project version string (e.g. "4.40")

# ── Git commit ───────────────────────────────────────────────────────────
find_package(Git QUIET)
if(GIT_FOUND AND EXISTS "${SOURCE_DIR}/.git")
    execute_process(
        COMMAND ${GIT_EXECUTABLE} rev-parse --short HEAD
        WORKING_DIRECTORY "${SOURCE_DIR}"
        OUTPUT_VARIABLE GIT_COMMIT_SHORT
        OUTPUT_STRIP_TRAILING_WHITESPACE
        ERROR_QUIET
        RESULT_VARIABLE GIT_RESULT
    )
    execute_process(
        COMMAND ${GIT_EXECUTABLE} rev-parse HEAD
        WORKING_DIRECTORY "${SOURCE_DIR}"
        OUTPUT_VARIABLE GIT_COMMIT_FULL
        OUTPUT_STRIP_TRAILING_WHITESPACE
        ERROR_QUIET
    )
    if(NOT GIT_RESULT EQUAL 0)
        set(GIT_COMMIT_SHORT "unknown")
        set(GIT_COMMIT_FULL  "unknown")
    endif()
else()
    set(GIT_COMMIT_SHORT "unknown")
    set(GIT_COMMIT_FULL  "unknown")
endif()

# ── Build timestamp (UTC) ────────────────────────────────────────────────
string(TIMESTAMP BUILD_DATE "%Y-%m-%d" UTC)
string(TIMESTAMP BUILD_TIME "%H:%M:%S" UTC)
string(TIMESTAMP BUILD_DATETIME "%Y-%m-%d %H:%M:%S UTC" UTC)

# ── Write header ─────────────────────────────────────────────────────────
file(WRITE "${OUTPUT_FILE}"
"// Auto-generated by cmake/generate_buildinfo.cmake — do not edit
#ifndef ALTIRRA_BUILDINFO_H
#define ALTIRRA_BUILDINFO_H

#define ALTIRRA_BUILD_VERSION    \"${PROJECT_VER}\"
#define ALTIRRA_BUILD_DATE       \"${BUILD_DATE}\"
#define ALTIRRA_BUILD_TIME       \"${BUILD_TIME}\"
#define ALTIRRA_BUILD_DATETIME   \"${BUILD_DATETIME}\"
#define ALTIRRA_BUILD_COMMIT     \"${GIT_COMMIT_SHORT}\"
#define ALTIRRA_BUILD_COMMIT_FULL \"${GIT_COMMIT_FULL}\"

#endif
")
